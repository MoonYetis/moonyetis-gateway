# MoonYetis x402 Gateway — Environment Configuration
# Copy this file to .env and fill in your values

# === Fractal Node RPC (via Tailscale) ===
FB_RPC_HOST=YOUR_TAILSCALE_IP
FB_RPC_PORT=8332
FB_RPC_USER=your_rpc_user
FB_RPC_PASS=your_rpc_password

# === x402 Facilitator ===
FACILITATOR_URL=http://127.0.0.1:4040

# === Service API Keys (from x402 facilitator registration) ===
RNG_SERVICE_KEY=ssk_your_rng_key
BALANCE_SERVICE_KEY=ssk_your_balance_key
TIMESTAMP_SERVICE_KEY=ssk_your_timestamp_key

# === Pricing (in sats — 1 FB = 100,000 sats) ===
RNG_PRICE_SATS=50000        # 0.5 FB
BALANCE_PRICE_SATS=10000    # 0.1 FB
TIMESTAMP_PRICE_SATS=200000 # 2.0 FB

# === Ports ===
RNG_PORT=4055
BALANCE_PORT=4056
TIMESTAMP_PORT=4057

# === Timestamp wallet (node wallet name with signing keys) ===
TIMESTAMP_WALLET=fractal_main
